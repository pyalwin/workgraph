# Local libsql-server (Docker) — option 3 from the dev DB walkthrough.
# Copy these lines into .env.local to point the app at the local container.
#
#   docker compose up -d libsql        # start the container (port 8080)
#   bash scripts/db-local-reset.sh     # wipe + restart for a fresh schema run
#
# vector_distance_cos() works in this mode — Phase 7 RAG vector search runs end-to-end.

# Required
DATABASE_URL=http://127.0.0.1:8081

# Leave the auth token UNSET in dev — the local server has no auth.
# TURSO_AUTH_TOKEN=

# (Everything else from your existing .env.local stays as-is — WORKOS_*,
# INNGEST_EVENT_KEY, HF_API_KEY, etc.)
